NODE_ENV=production
PORT=4000
# Render tự suy ra từ RENDER_EXTERNAL_HOSTNAME. Nền tảng khác cần đặt URL HTTPS này.
CLIENT_ORIGIN=https://your-domain.example

DB_HOST=your-mysql-host
DB_PORT=4000
DB_USER=your-production-user
DB_PASSWORD=use-a-secret-manager
DB_NAME=test
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=generate-at-least-32-random-characters
